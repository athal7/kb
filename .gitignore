# This repo's openspec/ specs and archived changes are real project
# documentation (not symlinks into the personal KB store like other repos on
# this machine), and are meant to be committed and reviewed like code.
# Re-include what the global ~/.config/git/ignore excludes by convention.
!/openspec/specs
!/openspec/changes/archive
!/openspec/config.yaml

